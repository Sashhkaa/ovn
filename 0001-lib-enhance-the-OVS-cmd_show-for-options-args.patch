From 842a9dedc7097b9070227fea3b99b43cf4a72b90 Mon Sep 17 00:00:00 2001
From: Alexandra Rukomoinikova <arukomoinikova@k2.cloud>
Date: Mon, 3 Mar 2025 01:14:28 +0300
Subject: [PATCH] lib: enhance the OVS cmd_show for options args
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

In the case of the ovn-sbctl command, it would be useful to display only
certain сhassis.

Signed-off-by: Alexandra Rukomoinikova <arukomoinikova@k2.cloud>
---
 lib/db-ctl-base.c     | 57 ++++++++++++++++++++++++++++++++++++++++---
 lib/db-ctl-base.h     |  1 +
 utilities/ovs-vsctl.c |  9 ++++++-
 vtep/vtep-ctl.c       |  8 +++++-
 4 files changed, 69 insertions(+), 6 deletions(-)

diff --git a/lib/db-ctl-base.c b/lib/db-ctl-base.c
index de046a4ed..7035a33dc 100644
--- a/lib/db-ctl-base.c
+++ b/lib/db-ctl-base.c
@@ -42,6 +42,19 @@
 
 VLOG_DEFINE_THIS_MODULE(db_ctl_base);
 
+#define INIT_CTL_COMMAND(max_args_val) \
+    {                            \
+        .name = "show",           \
+        .min_args = 0,             \
+        .max_args = max_args_val,   \
+        .arguments = "",             \
+        .prerequisites = pre_cmd_show,\
+        .run = cmd_show,               \
+        .postprocess = NULL,            \
+        .options = "",                   \
+        .mode = RO                        \
+    }
+
 /* This array defines the 'show' command output format.  User can check the
  * definition in utilities/ovs-vsctl.c as reference.
  *
@@ -2135,6 +2148,36 @@ cmd_show_weak_ref(struct ctl_context *ctx, const struct cmd_show_table *show,
     }
 }
 
+static bool
+cmd_show_row_filter(struct ctl_context *ctx, const struct ovsdb_idl_row *row)
+{
+    const struct cmd_show_table *show = cmd_show_find_table_by_row(row);
+    struct ds value = DS_EMPTY_INITIALIZER;
+    bool match_found = false;
+
+    for (size_t i = 0; i < ARRAY_SIZE(show->columns_filter); i++) {
+        const struct ovsdb_idl_column *column = show->columns_filter[i];
+        if (!column) {
+            continue;
+        }
+
+        const struct ovsdb_datum *datum = ovsdb_idl_read(row, column);
+        ovsdb_datum_to_string(datum, &column->type, &value);
+
+        for (size_t j = 1; j < ctx->argc; j++) {
+            if (value.string && !strcmp(value.string, ctx->argv[j])) {
+                match_found = true;
+                goto cleanup;
+            }
+        }
+        ds_clear(&value);
+    }
+
+cleanup:
+    ds_destroy(&value);
+    return match_found;
+}
+
 /* 'shown' records the tables that has been displayed by the current
  * command to avoid duplicated prints.
  */
@@ -2251,7 +2294,9 @@ cmd_show(struct ctl_context *ctx)
 
     for (row = ovsdb_idl_first_row(ctx->idl, cmd_show_tables[0].table);
          row; row = ovsdb_idl_next_row(row)) {
-        cmd_show_row(ctx, row, 0, &shown);
+        if (ctx->argc <= 1 || cmd_show_row_filter(ctx, row)) {
+            cmd_show_row(ctx, row, 0, &shown);
+        }
     }
 
     ovs_assert(sset_is_empty(&shown));
@@ -2547,9 +2592,13 @@ ctl_init__(const struct ovsdb_idl_class *idl_class_,
 
     cmd_show_tables = cmd_show_tables_;
     if (cmd_show_tables) {
-        static const struct ctl_command_syntax show =
-            {"show", 0, 0, "", pre_cmd_show, cmd_show, NULL, "", RO};
-        ctl_register_command(&show);
+        if (!cmd_show_tables->columns_filter) {
+            static const struct ctl_command_syntax show = INIT_CTL_COMMAND(0);
+            ctl_register_command(&show);
+        } else {
+            static const struct ctl_command_syntax show = INIT_CTL_COMMAND(INT_MAX);
+            ctl_register_command(&show);
+        }
     }
 }
 
diff --git a/lib/db-ctl-base.h b/lib/db-ctl-base.h
index ea7e97b78..828f41fa4 100644
--- a/lib/db-ctl-base.h
+++ b/lib/db-ctl-base.h
@@ -201,6 +201,7 @@ struct cmd_show_table {
     const struct ovsdb_idl_column *name_column;
     const struct ovsdb_idl_column *columns[4]; /* Seems like a good number. */
     const struct weak_ref_table wref_table;
+    const struct ovsdb_idl_column *columns_filter[3]; /* Seems like a good number. */
 };
 
 
